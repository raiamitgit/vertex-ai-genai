{
  "protocolVersion": "0.3.0",
  "name": "User Profile A2UI Agent",
  "description": "An agent that displays user profiles using A2UI cards.",
  "url": "http://localhost:8080",
  "version": "1.0.0",
  "capabilities": {
    "streaming": false,
    "preferredTransport": "JSONRPC",
    "extensions": [
      {
        "uri": "https://a2ui.org/a2a-extension/a2ui/v0.8",
        "required": false,
        "params": {
          "supportedCatalogIds": [
            "https://a2ui.org/specification/v0_8/standard_catalog_definition.json"
          ]
        }
      }
    ]
  },
  "skills": [
    {
      "id": "get_user_profile",
      "name": "Get User Profile",
      "description": "Fetch and display the current user profile.",
      "tags": ["User", "Profile", "A2UI"]
    }
  ],
  "defaultInputModes": ["text", "text/plain"],
  "defaultOutputModes": ["text", "text/plain"]
}
