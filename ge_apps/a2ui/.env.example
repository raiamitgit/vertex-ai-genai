# Google Cloud Configuration
GOOGLE_GENAI_USE_VERTEXAI=True
GOOGLE_CLOUD_PROJECT=YOUR_GCP_PROJECT_ID
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_CLOUD_PROJECT_NUMBER=YOUR_GCP_PROJECT_NUMBER

# Gemini Enterprise Integration (A2A Registration)
GEMINI_ENTERPRISE_APP_ID=YOUR_GEMINI_ENTERPRISE_ENGINE_ID
GEMINI_ENTERPRISE_LOCATION=global

# Custom A2UI Run Mode Toggle (repro | solved)
RUN_MODE=repro

# ServiceNow Credentials (PDI)
SN_INSTANCE_URL=https://YOUR_INSTANCE.service-now.com
SN_USERNAME=YOUR_USERNAME
SN_PASSWORD=YOUR_PASSWORD
